# --- your database ---------------------------------------------------------
# Use the least-privilege read-only role from sql/backup_role.sql, never the
# owner/postgres connection string. See docs/supabase.md for the Supabase path.
# Supavisor session pooler? Use sslmode=require — the pooler cert doesn't
# chain to a public CA, so verify-full needs the Supabase CA mounted.
BACKWYN_SOURCE_DSN=postgresql://backwyn_backup:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=verify-full

# --- encryption key --------------------------------------------------------
# Generate:  head -c32 /dev/urandom | base64
# Back this up somewhere that is NOT your artifact bucket
BACKWYN_ENCRYPTION_KEY=

# --- artifact storage ---------------------------
# s3 (default) or local. Under docker compose, local writes to ./backups on
# the host — leave BACKWYN_STORAGE_DIR at /backups (the in-container mount).
BACKWYN_STORAGE=s3
# BACKWYN_STORAGE_DIR=/backups

BACKWYN_S3_BUCKET=my-backups
BACKWYN_S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
BACKWYN_S3_REGION=auto
BACKWYN_S3_ACCESS_KEY=
BACKWYN_S3_SECRET_KEY=
BACKWYN_S3_PATH_STYLE=true



# --- verification ------------------------------------------------------------
# Optional SQL probe run against the restored sandbox; an error fails verify
# BACKWYN_VERIFY_QUERY=SELECT count(*) FROM customers;

# Optional: scope the dump to specific schemas (see docs/supabase.md before
# setting this — excluding auth means restored copies have no user accounts)
# BACKWYN_DUMP_SCHEMAS=public

# RLS-enabled tables (hosted Supabase): dump under the backup role's policies.
# Requires the read-all policies from sql/backup_role_rls.sql first — see
# docs/supabase.md#row-level-security-and-pg_dump.
# BACKWYN_DUMP_ROW_SECURITY=true

# --- alerting --------------------------------------------------------------
# Slack-style JSON by default; Discord webhook URLs get a Discord message.
BACKWYN_ALERT_WEBHOOK=

# --- observability -----------------------------------------------------------
# Daemon /healthz + /metrics address
# BACKWYN_LISTEN_ADDR=:8080

# --- schedule and retention ------------------------------------------------
BACKWYN_INTERVAL=6h        # time between backup+verify cycles
BACKWYN_MAX_AGE=24h        # alert if no VERIFIED backup is newer than this
BACKWYN_KEEP_DAILY=14
BACKWYN_KEEP_MONTHLY=12
